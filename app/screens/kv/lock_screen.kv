<LockScreen>:
    name: "lock"

    MDBoxLayout:
        orientation: "vertical"
        padding: "32dp"
        spacing: "16dp"

        Widget:

        MDIcon:
            icon: "lock"
            halign: "center"
            font_size: "56sp"

        MDLabel:
            text: "Enter PIN to unlock"
            halign: "center"
            font_style: "H6"
            adaptive_height: True

        MDTextField:
            id: pin_field
            hint_text: "PIN"
            password: True
            input_filter: "int"
            halign: "center"
            on_text_validate: root.unlock()

        MDLabel:
            id: error_label
            text: ""
            halign: "center"
            theme_text_color: "Error"
            adaptive_height: True

        MDRaisedButton:
            text: "Unlock"
            pos_hint: {"center_x": 0.5}
            on_release: root.unlock()

        Widget:
